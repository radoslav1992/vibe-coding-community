---
import Tag from './Tag.astro';
import { timeAgo } from '../lib/ui';
import type { Post } from '../lib/db';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const excerpt = post.body.length > 180 ? post.body.slice(0, 177).trimEnd() + '…' : post.body;
---
<article class="card post-card">
  <div class="post-card__votes">
    <button
      type="button"
      class:list={['vote-btn', 'js-vote', { 'vote-btn--on': post.voted }]}
      data-post-id={post.id}
      aria-label="Upvote"
    >▲</button>
    <span class="vote-count js-vote-count" data-post-id={post.id}>{post.votes}</span>
  </div>
  <div class="post-card__content">
    <div><Tag name={post.tag} /></div>
    <h3 class="post-card__title"><a href={`/post/${post.id}`}>{post.title}</a></h3>
    <p class="post-card__excerpt">{excerpt}</p>
    <div class="post-card__meta">
      <span style="color:#444">{post.author_name}</span>
      <span>{timeAgo(post.created_at)}</span>
      <a href={`/post/${post.id}`}>💬 {post.comment_count}</a>
    </div>
  </div>
</article>
