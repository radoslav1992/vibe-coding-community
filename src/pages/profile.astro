---
import Layout from '../layouts/Layout.astro';
import { timeAgo, initials, avatarGradient } from '../lib/ui';
import { userStats, userActivity, karmaPoints } from '../lib/db';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth');
const db = Astro.locals.runtime.env.DB;

const [stats, activity] = await Promise.all([userStats(db, user.id), userActivity(db, user.id)]);

const memberSince = new Date(user.created_at * 1000).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const roleLabel = user.role === 'admin' ? 'Admin' : user.role === 'moderator' ? 'Moderator' : null;
---
<Layout active="none" title={`${user.name} · VibeShipyard`}>
  <main class="page page--narrow stack">
    <div class="card profile-card">
      <div class="avatar avatar--lg" style={`background:${avatarGradient(user.id)}`}>{initials(user.name)}</div>
      <div style="flex:1;min-width:200px">
        <h1 style="margin:0;font-size:24px;font-weight:900;letter-spacing:-0.01em">{user.name}</h1>
        <div style="font-size:14px;color:var(--muted);font-weight:600">
          @{user.username} · member since {memberSince}
          {roleLabel && <> · <span style="color:var(--accent);font-weight:800">{roleLabel}</span></>}
        </div>
        {user.bio && <div style="font-size:14px;color:var(--body-text);margin-top:6px">{user.bio}</div>}
        <div style="font-size:13px;color:var(--faint);font-weight:600;margin-top:6px">
          Your public page: <a href={`/u/${user.username}`} style="color:var(--accent)">/u/{user.username}</a>
          {!user.public_profile && ' (visible to members only — change in Settings)'}
        </div>
      </div>
      <div class="profile-stats">
        <div><b>{stats.posts}</b><span>posts</span></div>
        <div><b>{stats.comments}</b><span>comments</span></div>
        <div><b>{karmaPoints(stats)}</b><span>points</span></div>
      </div>
    </div>

    <h2 style="margin:8px 0 0;font-size:16px;font-weight:800;color:#444">Recent activity</h2>
    <div class="card" style="overflow:hidden">
      {activity.map((a) => (
        <a href={`/post/${a.ref_id}`} class="activity-row" style="display:block">
          <div class="activity-row__kind">{a.kind === 'post' ? 'POST' : 'COMMENT'} · {timeAgo(a.created_at)}</div>
          {a.kind === 'post' ? (
            <div style="font-weight:800;font-size:15px">{a.title}</div>
          ) : (
            <div style="font-size:15px;color:var(--body-text)">“{a.title}”</div>
          )}
        </a>
      ))}
      {activity.length === 0 && (
        <div class="activity-row" style="color:var(--faint);font-weight:600">
          Nothing yet — <a href="/?compose=1#composer" style="color:var(--accent)">write your first post</a>.
        </div>
      )}
    </div>
  </main>
</Layout>
