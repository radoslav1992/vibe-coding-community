---
import Layout from '../layouts/Layout.astro';

interface CourseRow {
  id: number;
  level: 'BEGINNER' | 'INTERMEDIATE' | 'ADVANCED';
  title: string;
  description: string;
  meta: string;
  lesson_count: number;
  done_count: number;
}
interface ArticleRow {
  id: number;
  title: string;
  meta: string;
}

const LEVEL_COLORS: Record<string, string> = {
  BEGINNER: 'background:#DCE9FF;color:#2456C9',
  INTERMEDIATE: 'background:#FFE0F1;color:#C4005D',
  ADVANCED: 'background:#FFE4D3;color:#C24E00',
};

const db = Astro.locals.runtime.env.DB;
const user = Astro.locals.user;

const [{ results: courses }, { results: articles }] = await Promise.all([
  db
    .prepare(
      `SELECT c.*,
         (SELECT COUNT(*) FROM lessons l WHERE l.course_id = c.id) AS lesson_count,
         (SELECT COUNT(*) FROM lessons l JOIN lesson_completions lc ON lc.lesson_id = l.id AND lc.user_id = ?1
          WHERE l.course_id = c.id) AS done_count
       FROM courses c ORDER BY c.sort ASC`
    )
    .bind(user?.id ?? 0)
    .all<CourseRow>(),
  db.prepare('SELECT id, title, meta FROM articles ORDER BY sort ASC').all<ArticleRow>(),
]);
---
<Layout active="learn" title="Learn · VibeShipyard">
  <main class="page page--wide">
    <h1 class="page-title">Learn</h1>
    <p class="page-subtitle">Short courses and guides — from zero to a shipped product.</p>

    <div class="course-grid">
      {courses.map((course) => {
        const started = course.done_count > 0;
        const finished = course.lesson_count > 0 && course.done_count === course.lesson_count;
        return (
          <div class="card course-card">
            <span class="tag" style={`align-self:flex-start;letter-spacing:0.04em;${LEVEL_COLORS[course.level]}`}>{course.level}</span>
            <h3><a href={`/learn/course/${course.id}`} style="color:inherit">{course.title}</a></h3>
            <p>{course.description}</p>
            <div class="course-card__meta">{course.meta}</div>
            {user && started && (
              <div class="progress-bar" title={`${course.done_count} of ${course.lesson_count} lessons completed`}>
                <div class="progress-bar__fill" style={`width:${Math.round((course.done_count / course.lesson_count) * 100)}%`}></div>
              </div>
            )}
            <a href={`/learn/course/${course.id}`} class="btn btn--dark btn--block" style="padding:10px">
              {finished ? '✓ Completed — review' : started ? `Continue (${course.done_count}/${course.lesson_count})` : 'Start the course'}
            </a>
          </div>
        );
      })}
    </div>

    <h2 style="font-size:18px;font-weight:800;margin:0 0 14px">Articles &amp; resources</h2>
    <div class="card" style="overflow:hidden">
      {articles.map((a) => (
        <a href={`/learn/article/${a.id}`} class="list-row" style="display:flex">
          <div>
            <div class="list-row__title">{a.title}</div>
            <div class="list-row__meta">{a.meta}</div>
          </div>
          <span class="list-row__arrow">→</span>
        </a>
      ))}
    </div>
  </main>
</Layout>
