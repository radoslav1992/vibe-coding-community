---
import Layout from '../../layouts/Layout.astro';
import { longDate } from '../../lib/ui';

interface NewsRow {
  id: number;
  title: string;
  body: string;
  featured: number;
  published_at: number;
}

const db = Astro.locals.runtime.env.DB;

const id = Number(Astro.params.id);
if (!Number.isInteger(id) || id < 1) return Astro.redirect('/news');

const item = await db.prepare('SELECT * FROM news WHERE id = ?1').bind(id).first<NewsRow>();
if (!item) return Astro.redirect('/news');

const paragraphs = item.body.split(/\n\s*\n/).filter(Boolean);
---
<Layout active="news" title={`${item.title} · VibeShipyard`}>
  <main class="page page--narrow stack">
    <a href="/news" class="back-link">← Back to News</a>

    <article class="card thread-card">
      <div style="font-size:13px;color:var(--faint);font-weight:700;margin-bottom:8px">
        {longDate(item.published_at)}{item.featured ? ' · FEATURED' : ''}
      </div>
      <h1 class="thread-title">{item.title}</h1>
      <div class="prose">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </article>
  </main>
</Layout>
